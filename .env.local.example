# Arc App Kit — get your kit key from https://console.circle.com
NEXT_PUBLIC_ARC_KIT_KEY=your_kit_key_here

# WalletConnect Project ID — get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# RPC URLs (optional — App Kit has built-in defaults)
NEXT_PUBLIC_ARC_TESTNET_RPC=https://rpc.arc.io
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://rpc.sepolia.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://base-sepolia.publicnode.com
NEXT_PUBLIC_ARB_SEPOLIA_RPC=https://arbitrum-sepolia.publicnode.com
NEXT_PUBLIC_OP_SEPOLIA_RPC=https://optimism-sepolia.publicnode.com
